# ============================================================
# 蛟龍祭クラス企画評価 - 環境変数サンプル
# このファイルを .env.local にコピーして値を設定してください。
# Vercelにデプロイする場合は、Project Settings > Environment Variables
# に同じキーで設定します。
# ============================================================

# --- ログインID/パスワード/クラス（Supabase未設定時のフォールバック）----
# Supabaseを設定する場合はこちらは使われません（accountsテーブルが優先）。
# 形式: ログインID:パスワード:表示名:classId をカンマ区切りで複数指定
AUTH_USERS=admin:changeme:管理者:admin,1-1:abcd1234:1年1組:1-1,1-2:efgh5678:1年2組:1-2

# --- NextAuth ---------------------------------------------------
# 任意のランダム文字列（`openssl rand -base64 32` などで生成）
NEXTAUTH_SECRET=replace-with-random-string
# 本番URL（Vercelの場合は自動設定されることが多いですが念のため）
NEXTAUTH_URL=https://your-app.vercel.app

# --- Google ログインを使う場合のみ（任意） ----------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Supabase（ログインアカウント・評価データの保存先） -----------
# 1. NEXT_PUBLIC_SUPABASE_URL              : Project Settings > API > Project URL
# 2. NEXT_PUBLIC_SUPABASE_ANON_KEY         : 同ページ > anon public key
# 3. SUPABASE_SERVICE_ROLE_KEY             : 同ページ > service_role key
#    ※ service_role key は絶対に公開しないこと（RLSをバイパスする強力な鍵）
#    ※ NEXT_PUBLIC_ が付いていないのでブラウザには送られません
#
# supabase/schema.sql を実行してテーブルを作成し、
# scripts/createAccounts.ts でアカウントを登録してください。
NEXT_PUBLIC_SUPABASE_URL=https://fyfncbhyhuiejovhzarb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZ5Zm5jYmh5aHVpZWpvdmh6YXJiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA0NDYxMDMsImV4cCI6MjA4NjAyMjEwM30.Nio2FS8OmiyMW8FOx-37NY-4y_xBe4UFkNRPO2RVPXs
